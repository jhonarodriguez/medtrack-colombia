# ─── Algolia API (Farmatodo) ────────────────────────────────────────────────
# Estos son search-only keys (sin permisos de escritura, seguro en cliente)
# Obtener desde: https://www.algolia.com/account/api-keys
ALGOLIA_APP_ID=VCOJEYD2PO
ALGOLIA_API_KEY=eb9544fe7bfe7ec4c1aa5e5bf7740feb
ALGOLIA_INDEX=products-colombia

# ─── Google Maps Geocoding API (OPCIONAL) ────────────────────────────────────
# Google Maps mejora la precisión de geocodificación (especialmente barrios)
# Sin esta key: funciona con Nominatim (gratis, menos preciso)
# Con esta key: 25,000 geocodificaciones gratis/mes (suficiente para mayoría de usuarios)
# 
# Cómo obtener:
# 1. Ve a https://console.cloud.google.com
# 2. Crea un proyecto
# 3. Habilita "Geocoding API"
# 4. Crea una API key en "Credentials"
# 5. (Opcional) Restricciona para usarla solo con Geocoding API
# 
# Una vez obtenida:
# GOOGLE_MAPS_API_KEY=AIzaSyD_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (dejar vacío o comentado para usar solo Nominatim)
# GOOGLE_MAPS_API_KEY=

# ─── Timeouts ───────────────────────────────────────────────────────────────
# Timeout para scrapers con Playwright (ms)
PLAYWRIGHT_TIMEOUT=20000

# Timeout para requests HTTP con Cheerio/axios (ms)
HTTP_TIMEOUT=10000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Máximo de requests concurrentes por farmacia
MAX_CONCURRENT_PER_PHARMACY=2

# Delay entre requests al mismo dominio (ms)
REQUEST_DELAY_MS=1000

# ─── Caché ───────────────────────────────────────────────────────────────────
# TTL para precios de farmacias (segundos)
CACHE_PRICES_TTL=1800

# TTL para datos de INVIMA (segundos)
CACHE_INVIMA_TTL=604800

# TTL para geocodificación (segundos)
CACHE_GEO_TTL=604800

# ─── Proxy (opcional) ────────────────────────────────────────────────────────
# HTTP_PROXY=http://user:pass@host:port

# ─── Logging ─────────────────────────────────────────────────────────────────
# Nivel de log: error | warn | info | debug
LOG_LEVEL=info

# ─── Modo HTTP (opcional, para despliegue cloud) ─────────────────────────────
# Por defecto el servidor usa stdio (para Claude Desktop, Cursor, etc.)
# Descomentar para usar transporte HTTP
# TRANSPORT=http
# PORT=3000
